# Expo public env vars — must be prefixed with EXPO_PUBLIC_ to be included in the bundle.
# Point to your local NestJS API.
# If testing on physical device via Expo Go, replace localhost with your machine's IP
# (e.g., 192.168.1.20). Run `ipconfig getifaddr en0` to find it on macOS.
EXPO_PUBLIC_API_URL=http://localhost:3001/api

# For production:
# EXPO_PUBLIC_API_URL=https://api.bloodlineph.com/api
