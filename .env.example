# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/sabong_marketplace

# API
API_PORT=3001
WEB_URL=http://localhost:3000

# JWT (generate new ones for production!)
JWT_SECRET=your-secret-here-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-here-min-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# AI Chat
ANTHROPIC_API_KEY=sk-ant-...

# Payments (PayMongo)
PAYMONGO_SECRET_KEY=sk_test_...
PAYMONGO_PUBLIC_KEY=pk_test_...
PAYMONGO_WEBHOOK_SECRET=whsec_...

# Storage (Cloudflare R2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=sabongmarket
R2_PUBLIC_URL=https://your-r2-public.domain.com

# SMS (Semaphore)
SEMAPHORE_API_KEY=
SEMAPHORE_SENDER_NAME=SabongMkt

# Error tracking (Sentry)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Email / Waitlist (Resend) — used by /api/waitlist
# Sign up at https://resend.com (free 3k emails/mo)
RESEND_API_KEY=re_...
RESEND_AUDIENCE_ID=
# Optional: get an email on every new waitlist signup
NOTIFY_EMAIL=you@example.com
# Optional: branded sender. Must be verified domain or use default
RESEND_FROM_EMAIL=BloodlinePH <onboarding@resend.dev>

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_SITE_URL=https://bloodlineph.com
