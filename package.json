{
  "name": "sabong-marketplace",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "db:generate": "turbo db:generate --filter=@sabong/api",
    "db:migrate": "turbo db:migrate --filter=@sabong/api",
    "db:seed": "turbo db:seed --filter=@sabong/api",
    "test": "turbo test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "turbo": "^2.4",
    "typescript": "^5.7"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "overrides": {
      "pretty-format": "^29.7.0"
    }
  }
}
